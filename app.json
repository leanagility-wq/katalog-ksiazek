{
  "expo": {
    "name": "Katalog Ksiazek",
    "slug": "katalog-ksiazek",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "pl.katalogksiazek.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5ebdb"
      },
      "permissions": [
        "CAMERA",
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store"
    ]
  }
}
